#include <iostream>
using namespace std;

// Variabel global
int n;
int choice;

// Fungsi cek bilangan prima
bool isPrime(int num) 
{
    if (num <= 1) return false;   // angka <=1 bukan prima
    int i = 2;
    while (i <= num / 2) 
    {
        if (num % i == 0) return false; // ada faktor pembagi
        i++;
    }
    return true; // jika tidak ada faktor pembagi
}

