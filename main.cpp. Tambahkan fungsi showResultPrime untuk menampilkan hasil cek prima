#include <iostream>
using namespace std;

// Variabel global
int n;
int choice;

// Fungsi cek bilangan prima
bool isPrime(int num) {
    if (num <= 1) return false;
    int i = 2;
    while (i <= num / 2) {
        if (num % i == 0) return false;
        i++;
    }
    return true;
}

// Fungsi cek bilangan Fibonacci
bool isFibonacci(int num) {
    if (num < 0) return false;
    int a = 0, b = 1;
    while (b < num) {
        int temp = a + b;
        a = b;
        b = temp;
    }
    return (num == a || num == b);
}

// Fungsi input angka dari user
void inputNumber() {
    cout << "Masukkan angka (>=1): ";
    cin >> n;
    if (n < 1) {
        cout << "Input tidak valid. Angka harus >= 1.\n";
        n = 1; // fallback default
    }
}

// Fungsi menampilkan hasil cek prima
void showResultPrime() {
    if (isPrime(n)) {
        cout << n << " adalah bilangan prima.\n";
    } else {
        cout << n << " bukan bilangan prima.\n";
    }
}

