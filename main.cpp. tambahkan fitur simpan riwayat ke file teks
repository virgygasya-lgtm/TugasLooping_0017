    ofstream file("riwayat.txt");
    if (!file) 
    {
        cout << "Gagal membuat file riwayat.\n";
        return;
    }

    file << "=== Riwayat Input Angka ===\n";
    if (history.empty()) {
        file << "Belum ada angka yang dicek.\n";
