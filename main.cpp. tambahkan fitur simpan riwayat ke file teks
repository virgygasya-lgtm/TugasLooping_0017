int main() 
{
    cout << "=== Selamat datang di Program Tugas Looping ===\n";
    cout << "Program ini dapat mengecek bilangan prima dan Fibonacci.\n";

    do 
    {
        showMenu();
        switch (choice) 
        {
            case 1:
                inputNumber();
                showResultPrime();
                break;
            case 2:
                inputNumber();
                showResultFibonacci();
                break;
            case 3:
                showHistory();
                break;
            case 4:
                clearHistory();
                break;
            case 5:
                saveHistoryToFile();
                break;
            case 0:
                cout << "Terima kasih telah menggunakan program ini.\n";
                break;
            default:
                cout << "Pilihan tidak valid. Silakan coba lagi.\n";
        }
    } while (choice != 0);

    cout << "=== Program selesai ===\n";
    return 0;
}